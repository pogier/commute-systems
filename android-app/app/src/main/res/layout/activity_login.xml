<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp"
    android:background="#0F1117">

    <TextView
        android:text="🚌"
        android:textSize="48sp"
        android:gravity="center"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:text="Commute System"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#E8EAF0"
        android:gravity="center"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="40dp"/>

    <EditText
        android:id="@+id/emailInput"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:hint="Email address"
        android:inputType="textEmailAddress"
        android:textColor="#E8EAF0"
        android:textColorHint="#8B92A9"
        android:padding="12dp"
        android:background="#1A1D27"
        android:layout_marginBottom="12dp"/>

    <EditText
        android:id="@+id/passwordInput"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:hint="Password"
        android:inputType="textPassword"
        android:textColor="#E8EAF0"
        android:textColorHint="#8B92A9"
        android:padding="12dp"
        android:background="#1A1D27"
        android:layout_marginBottom="24dp"/>

    <Button
        android:id="@+id/loginButton"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="Sign In"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:backgroundTint="#4F8EF7"
        android:layout_marginBottom="16dp"/>

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:id="@+id/registerLink"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="No account? Register here"
        android:textColor="#4F8EF7"
        android:textSize="14sp"
        android:layout_gravity="center"/>

</LinearLayout>